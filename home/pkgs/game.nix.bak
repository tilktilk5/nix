{ pkgs, ... }:

{
	home.packages = with pkgs; [
		(dwarf-fortress-packages.dwarf-fortress-full.override {
  			dfVersion = "0.47.05";
  			theme = "cla";
  			enableIntro = false;
  			enableFPS = true;
			enableDwarfTherapist = false;
		})
		#dwarf-fortress-packages.dwarf-fortress-full
		#dwarf-fortress-packages.dwarf-fortress_0_47_05	
	];
}
